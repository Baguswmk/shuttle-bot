# Telegram
BOT_TOKEN=your_bot_token_here_from_botfather

# Database (PostgreSQL di VPS — isi setelah install PostgreSQL)
DATABASE_URL=postgresql://shuttle_user:your_password@localhost:5432/your_campus_shuttle

# API Auth
JWT_SECRET=ganti_ini_dengan_string_acak_minimal_32_karakter
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_ini_minimal_8_karakter

# Server
PORT=3002
NODE_ENV=development

# Webhook (untuk production di VPS, kosongkan untuk dev)
WEBHOOK_URL=

# ── Konfigurasi Kampus ────────────────────────────────────────────────────────
# Sesuaikan variabel di bawah dengan identitas kampusmu.
# Semua memiliki nilai default, tapi sangat disarankan untuk diisi.

# Nama lengkap platform yang tampil di pesan bot
BOT_NAME=Nama Kampus Shuttle Bot

# Singkatan nama kampus (tampil di pesan selamat datang)
CAMPUS_NAME=NAMASINGKATAN

# Kota lokasi kampus
CAMPUS_CITY=NamaKota

# Contoh lokasi jemput yang ditampilkan sebagai hint di form Antar Jemput
PICKUP_EXAMPLE=Gedung A, Fakultas Teknik

# Prefix folder Cloudinary untuk upload KTM/selfie
# Pisahkan per kampus agar aset tidak campur
# Contoh: "unnes-shuttle", "undip-shuttle", "ugm-shuttle"
STORAGE_PREFIX=nama-kampus-shuttle

# Daftar zona driver, dipisah koma (tanpa spasi di antara koma)
# Driver akan memilih zona aktif mereka saat mau online
# Contoh untuk : Sekaran,FT,FIS,FIK,FBS,FIP,FH,FE,Gerbang Utama
DRIVER_ZONES=Kampus Utama,Zona A,Zona B
